// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ESQUEMA DE PRISMA
// Puedes primero crear las tablas manualmente en la base de datos o usar Prisma para crearlas
// Si usas Prisma, ejecuta 'npx prisma db push' para crear las tablas en la base de datos
// Si usas DBeaver, puedes crear las tablas manualmente en la base de datos

// En este caso se utilizara Prisma para crear las tablas en la base de datos
// Recuerda tener instalada la extension de Prisma en el IDE

// ENUMS - Tienen valores predefinidos
// Debes colocar todas las tallas
enum Size {
  XS
  S
  M
  L
  XL
  XXL
  XXXL
}

enum Gender {
  men
  women
  kid
  unisex
}

// Roles de usuario
enum Role {
  admin
  user
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  // Relacion uno a muchos
  products Product[]
}

model Product {
  id          String @id @default(uuid())
  title       String
  description String
  inStock     Int

  // Valor de tipo decimal
  // Recordar que @default estalece el valor por defecto
  price Float @default(0)

  sizes Size[]   @default([])
  slug  String   @unique
  tags  String[] @default([])

  // Utiliza un enum para el genero
  gender Gender

  // Cada producto tiene una categoria
  // references es para indicar que la columna categoryId es una foreign key
  // y que referencia a la columna id de la tabla Category
  category   Category @relation(fields: [categoryId], references: [id])
  categoryId String

  // Por alguna razon este campo se añade automaticamente cuando hace una relación en el 
  // modelo de ProductImage
  productImages ProductImage[]

  // Relación con los items de la orden
  orderItems OrderItem[]

  // Crea un indice para la columna gender
  @@index([gender])
}

// Ejecuta `npx prisma migrate dev --name ProductCategory` para ejecutar la primera migración
// Y luego `npx prisma generate` para generar los modelos

// Ahora vamos a crear los modelos para las imagenes de los productos
model ProductImage {
  id  Int    @id @default(autoincrement())
  url String

  // Relación uno a muchos
  product   Product @relation(fields: [productId], references: [id])
  productId String
}

// Modelo de usuario
model User {
  // Identificador único
  id            String    @id @default(uuid())
  name          String
  // @unique significa que el email debe ser unico
  email         String    @unique
  // DateTime? significa que el campo puede ser nulo
  emailVerified DateTime?
  password      String
  // @default(user) significa que el valor por defecto es user
  role          Role      @default(user)
  image         String?

  // Relación de uno a uno 
  // un usuario opcionalmente tiene una direccion
  address UserAddress?

  // Relación de uno a muchos
  // un usuario puede tener muchas ordenes
  orders Order[]
}

// Recuerda para aplicar los cambios en la base de datos, ejecuta 
// 'npx prisma migrate dev --name user_role' (se asigno el nombre de la migración
// 'user role') y luego 'npx prisma generate' para generar el cliente de prisma y
// las relaciones entre los modelos

// Modelo de paises
model Country {
  id   String @id
  name String

  // Relacion hacia UserAddress
  userAddresses UserAddress[]

  // Relacion hacia OrderAddress
  orderAddress OrderAddress[]
}

// Direccion del usuario
model UserAddress {
  id         String  @id @default(uuid())
  firstName  String
  lastName   String
  address    String
  address2   String?
  city       String
  postalCode String
  phone      String

  // Relaciones
  // Un pais puede tener muchos usuarios con direccion
  country   Country @relation(fields: [countryId], references: [id])
  countryId String

  // Relación de uno a uno (un usuario tiene una direccion)
  user   User   @relation(fields: [userId], references: [id])
  userId String @unique
}

// Orden de compras
model Order {
  id String @id @default(uuid())

  // Subtotal, impuesto y total a pagar
  // Float es el tipo de dato número decimal
  subTotal Float
  tax      Float
  total    Float

  // Numero de items en la orden
  itesmInOrder Int

  // ¿Ha pagado?
  isPaid Boolean @default(false)

  // Fecha de pago
  paidAt DateTime?

  // Fechas de creación y actualización
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relación con el usuario
  user   User   @relation(fields: [userId], references: [id])
  userId String

  // Relación con los items de la orden
  orderItems OrderItem[]

  // Relación uno a uno con la dirección de la orden (es opcional)
  orderAddress OrderAddress?
}

// Item de una orden
model OrderItem {
  id       String @id @default(uuid())
  quantity Int

  // Se guarda el precio en el momento de la compra
  // Porque los precios son dinamicos, el precio se guarda
  price Float

  // Talla, toma un valor de enum Size
  size Size

  // Relación con la orden
  order   Order  @relation(fields: [orderId], references: [id])
  orderId String

  // Recordar que al guardar este archivo, se crea la relación con la tabla Order
  // y se agrega la columna orderItems a la tabla Order

  // Relación con el producto
  product   Product @relation(fields: [productId], references: [id])
  productId String
}

// Dirección de entrega de la orden
// No es la misma que la direccion del usuario (UserAddress)
model OrderAddress {
  id         String  @id @default(uuid())
  firstName  String
  lastName   String
  address    String
  address2   String?
  city       String
  postalCode String
  phone      String

  // Relación con pais
  country   Country @relation(fields: [countryId], references: [id])
  countryId String

  // Relación con la orden
  order   Order  @relation(fields: [orderId], references: [id])
  // La orden solo puede tener una dirección, para aquello se utiliza @unique
  orderId String @unique
}

// Resumen para aplicar los cambios en la base de datos
// npx prisma migrate dev --name <Nombre_Migración>
// npx prisma generate
