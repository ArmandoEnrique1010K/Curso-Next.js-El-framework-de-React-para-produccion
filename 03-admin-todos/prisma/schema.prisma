// PRISMA ORM
// https://www.prisma.io/docs/orm/v6/overview/introduction/what-is-prisma
// Prisma es un ORM (Object-Relational Mapping) que permite interactuar con la base de datos 
// de manera más sencilla.
// Sirve para modelar objetos que representan las tablas de la base de datos, evitando escribir
// consultas SQL o queries.

// Incluye:
// - Prisma Client (genera el código para interactuar con la base de datos)
// - Prisma Migrate (genera las migraciones) 
// - Prisma Studio (interfaz gráfica para interactuar con la base de datos)

// GUIA DE PRISMA ORM
// https://vercel.com/kb/guide/nextjs-prisma-postgres

// Ejecuta el comando 'npx prisma init' para inicializar Prisma
// El comando creara el archivo .env que contiene la URL de la base de datos y la carpeta prisma

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

// Provider de postgresql que se conecta a la base de datos
datasource db {
  provider = "postgresql"
}

// 

// MODELADO DE TABLAS

// Modelo que representa la tabla de la base de datos, en este caso una tarea
model Todo {
  // Utiliza la tabulación para definir los campos de la tabla
  // El campo id es de tipo string
  // @id sirve para definir que el campo es la llave primaria
  // @default(uuid()) genera un UUID automáticamente y lo utiliza como valor por defecto
  id          String   @id @default(uuid())
  description String
  complete    Boolean  @default(false)
  // DateTime es un tipo de dato que representa una fecha y hora
  // @default(now()) genera la fecha actual automáticamente y lo utiliza como valor por defecto
  createdAt   DateTime @default(now())
  // @updatedAt actualiza la fecha automáticamente cuando se actualiza el registro
  updatedAt   DateTime @updatedAt
}

// Cada vez que se quiera hacer un cambio en el modelado de tablas, se tiene que hacer una 
// migración para que los cambios se reflejen en la base de datos

// Para aquello ejecuta el comando `npx prisma migrate dev`, a su vez te pedira un nombre
// para la migración (el nombre es libre, pero se recomienda ser descriptivo)

// Abre DBeaver y revisa si se ha creado las tablas correspondientes a los modelos

// Luego ejecuta `npx prisma generate` para generar el cliente de prisma para hacer
// las manipulaciones con la base de datos

// Pero para trabajar con Next.js se recomienda crear un archivo de configuración
// en la carpeta src/lib/prisma.ts

// Vuelve a ejecutar `npx prisma generate` para confirmar los cambios

// PRISMA CLI
// https://www.prisma.io/docs/orm/reference/prisma-cli-reference

// Al ejecutar `npx prisma db push`, se toma la definición del schema.prisma y la sincroniza con la base de datos
// `db pull` sirve para conectar la base de datos existente y añade los modelos correspondientes al schema.prisma,
// sirve cuando se tiene la base de datos creada y se quiere generar los modelos correspondientes

// En DBeaver crea la tabla Employee con los campos:
// Haz doble clic en la tabla para abrir el editor de la tabla, ve a la pestaña propiedades y en la sección columnas
// pulsa ALT + INSERT para agregar una nueva columna

// Nombre       Tipo de dato      Collation     ¿nulo?      Valor por defecto
// id           serial            default       NO        
// name         varchar                         NO         
// isadmin      boolean                         NO          false
// createdAt    timestamp                       NO          NOW()

// Puedes ejecutar el siguiente script en DBeaver
/**
 * CREATE TABLE Employee (
 * id SERIAL PRIMARY KEY,
 * name VARCHAR(255),
 * is_admin BOOLEAN DEFAULT FALSE,
 * created_at TIMESTAMP DEFAULT NOW()
 * );
 */

// Ahora ejecuta en la consola `npx prisma db pull` y escribe automaticamente el siguiente código:
// Pero elimina todos los comentarios escritos en schema.prisma (este archivo)
model employee {
  id         Int       @id @default(autoincrement())
  name       String?   @db.VarChar(255)
  is_admin   Boolean?  @default(false)
  created_at DateTime? @default(now()) @db.Timestamp(6)
  // Luego ejecuta `npx prisma generate` para generar el cliente de prisma

  // Puedes hacer modificaciones a la tabla
  // Por ejemplo, agregar un campo roles que sea un array de strings
  roles String[] @default([])

  // Pero al ejecutar `npx prisma migrate dev` se mostrara una advertencia de que todos los datos se perderán
  // además de añadir la columna roles a la tabla

  // Pero si ejecutas `npx prisma db push` hace la sincronizacion de la base de datos sin pasar por las migraciones
  // Solamente se utiliza para pruebas en la base de datos, antes de ejecutar un `npx prisma db pull`
}

